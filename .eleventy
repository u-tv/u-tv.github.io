
        .                     
        

        window.onscroll = () => { if (!isSearching && (window.innerHeight + window.scrollY) >= document.body.offsetHeight - 1000) loadContent(true); };
        document.addEventListener('DOMContentLoaded', () => { loadDailyAutoPosts(); loadContent(); });
    })();
    </script>
</body>
</html>

module.exports = function(eleventyConfig) {
  // पुरानी फाइल्स (जैसे robots.txt, sitemap.xml) को कॉपी करने के लिए
  eleventyConfig.addPassthroughCopy("robots.txt");
  eleventyConfig.addPassthroughCopy("sitemap.xml");
  eleventyConfig.addPassthroughCopy("logo.png");

  return {
    dir: {
      input: ".",
      output: "_site"
    }
  };
};

                    
