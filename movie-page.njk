---
pagination:
    data: movies
    size: 1
    alias: movie
permalink: "movies/{{ movie.slug }}/index.html"
---
<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ movie.title }} Full Movie Watch Online - MyMovies</title>
    <meta name="description" content="Watch {{ movie.title }} online for free. Rating: {{ movie.rating }}. HD Quality.">
    <style>
        body { background: #000; color: #fff; font-family: sans-serif; text-align: center; margin: 0; }
        .wrapper { max-width: 1000px; margin: auto; padding: 20px; }
        iframe { width: 100%; aspect-ratio: 16/9; border: 2px solid #333; border-radius: 8px; }
        .meta { background: #1a1a1a; padding: 20px; border-radius: 10px; margin-top: 20px; }
    </style>
</head>
<body>
    <div class="wrapper">
        <h1>{{ movie.title }}</h1>
        <img src="{{ movie.poster }}" width="200" style="border-radius: 10px;">
        <div class="meta">
            <p>IMDb Rating: ⭐ {{ movie.rating }} / 10</p>
        </div>
        <iframe src="{{ movie.embed_url }}" allowfullscreen></iframe>
    </div>
</body>
</html>
