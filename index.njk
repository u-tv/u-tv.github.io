<!DOCTYPE html>
<html>
<head>
    <title>Watch Online Movies - Free Streaming</title>
    <style>
        body { background: #111; color: #fff; font-family: sans-serif; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; padding: 40px; }
        .card { background: #222; padding: 10px; border-radius: 10px; text-decoration: none; color: #fff; text-align: center; }
        .card img { width: 100%; border-radius: 8px; }
    </style>
</head>
<body>
    <h1 style="text-align:center;">Latest Movies</h1>
    <div class="grid">
        {% for movie in movies %}
        <a href="/movies/{{ movie.slug }}/" class="card">
            <img src="{{ movie.poster }}">
            <h3>{{ movie.title }}</h3>
        </a>
        {% endfor %}
    </div>
</body>
</html>
