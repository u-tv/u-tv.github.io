import requests
import json
import time
import os

# ⚙️ CONFIG
TMDB_API_KEY = "TU-API-KEY-YAHA"
BASE_URL = "https://api.themoviedb.org/3"
HEADER = {"Authorization": f"Bearer {TMDB_API_KEY}"}

# Input file
TITLE_FILE = "movie_titles.txt"        # ya "titles.json"
OUTPUT_FILE = "movies.json"            # final metadata file
MAX_RETRY = 3


def read_titles():
    if not os.path.exists(TITLE_FILE):
        raise FileNotFoundError(f"Create {TITLE_FILE} with one movie title per line.")

    titles = []
    with open(TITLE_FILE, encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if line:
                titles.append(line)
    return titles


def search_tmdb(title, retry=0):
    url = f"{BASE_URL}/search/movie"
    params = {"query": title, "language": "hi,en"}

    try:
        resp = requests.get(url, headers=HEADER, params=params, timeout=10)
        if resp.status_code != 200:
            if retry < MAX_RETRY:
                time.sleep(2)
                return search_tmdb(title, retry + 1)
            return None

        data = resp.json()
        if data["results"]:
            return data["results"][0]  # choose first best match
        return None
    except Exception as e:
        print(f"Error searching {title}: {e}")
        return None


def fetch_movie_details(tmdb_id, retry=0):
    url = f"{BASE_URL}/movie/{tmdb_id}"
    params = {"language": "hi,en"}

    try:
        resp = requests.get(url, headers=HEADER, params=params, timeout=10)
        if resp.status_code != 200:
            if retry < MAX_RETRY:
                time.sleep(2)
                return fetch_movie_details(tmdb_id, retry + 1)
            return None

        return resp.json()
    except Exception as e:
        print(f"Error fetching {tmdb_id}: {e}")
        return None


def main():
    titles = read_titles()
    movies = []

    for i, title in enumerate(titles, 1):
        print(f"[{i}/{len(titles)}] Searching: {title}")

        res = search_tmdb(title)
        if not res:
            print("  ❌ Not found on TMDB. Skipping.")
            continue

        tmdb_id = res["id"]
        detail = fetch_movie_details(tmdb_id)
        if not detail:
            print("  ❌ Detail fetch failed.")
            continue

        # Normalize
        title_clean = detail.get("title") or detail.get("original_title", "Unknown")
        overview = detail.get("overview", "").strip()
        release_date = detail.get("release_date", "")
        year = release_date[:4] if release_date else "2025"
        genres = [g["name"] for g in detail.get("genres", [])]
        poster = "https://image.tmdb.org/t/p/w500" + detail.get("poster_path", "")

        movies.append({
            "id": i,  # local numeric id for file
            "name": title,
            "tmdb_id": tmdb_id,
            "title": title_clean,
            "overview": overview,
            "year": year,
            "lang": detail.get("original_language", "en"),
            "genres": genres,
            "poster": poster
        })

        time.sleep(0.25)  # respect rate limit

    with open(OUTPUT_FILE, "w", encoding="utf-8") as f:
        json.dump(movies, f, ensure_ascii=False, indent=2)

    print(f"
✅ Done. {len(movies)} movies saved to {OUTPUT_FILE}.")


if __name__ == "__main__":
    main()
